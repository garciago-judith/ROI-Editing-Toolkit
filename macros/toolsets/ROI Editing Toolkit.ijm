/*
 * ROI Editing Toolkit
 *
 * Load once from the ImageJ/Fiji toolbar >> menu.
 * Both buttons are installed together.
 * Icons are embedded ImageJ macro icon codes; no PNG files are used.
 */

macro "Delete ROIs in Region Action Tool - C900R11ddL33bbL3bb3" {
    doCommand("Delete ROIs in Region");
}

macro "Zoom Control Action Tool - C00fO4488L88ccLcc99L99dd" {
    doCommand("Zoom Control");
}
